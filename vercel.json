{
  "rewrites": [
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/digest",
      "schedule": "0 8 * * 1"
    }
  ],
  "functions": {
    "api/anthropic.ts":       { "maxDuration": 60 },
    "api/extract-keywords.ts": { "maxDuration": 60 },
    "api/scan.ts":             { "maxDuration": 60 },
    "api/scan-reddit.ts":      { "maxDuration": 60 },
    "api/scan-hn.ts":          { "maxDuration": 60 },
    "api/scan-ih.ts":          { "maxDuration": 60 },
    "api/score-matches.ts":    { "maxDuration": 60 },
    "api/digest.ts":           { "maxDuration": 60 }
  }
}
